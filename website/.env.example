# ─────────────────────────────────────────────────────────────────────────────
# Fittin' — environment variables. Copy to .env.local for dev; set the same keys in
# the Vercel project (Production) for go-live. NEXT_PUBLIC_* are baked in at BUILD time,
# so changing them in Vercel requires a redeploy.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Project Settings → API) ──
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key      # server only — never exposed to the browser
# Used by the migration script (scripts/migrate-mgmt.mjs):
SUPABASE_ACCESS_TOKEN=your-management-api-token
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_URL=postgresql://...                      # optional, for direct psql

# ── Public site URL ──  PROD MUST be https://fittin.be (used for Stripe redirects, OAuth, e-mail links).
NEXT_PUBLIC_SITE_URL=http://localhost:3008            # dev value; in Vercel Production set https://fittin.be

# ── Stripe (LIVE keys for production) ──
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...                       # from the LIVE webhook endpoint pointing at https://fittin.be/api/stripe/webhook

# ── Resend (transactional + newsletter e-mail) ──
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=whsec_...                       # Resend → Webhooks (delivery/open events)
RESEND_INBOUND_SECRET=...                             # inbound-parse secret (reply handling)

# ── Cron / background jobs (Vercel Cron sends this as a Bearer token) ──
CRON_SECRET=long-random-string

# ── Nuki smart lock (door codes). Can also be set per-gym in Beheer → Instellingen. ──
NUKI_API_TOKEN=your-nuki-web-api-token
NUKI_SMARTLOCK_ID=your-smartlock-id
